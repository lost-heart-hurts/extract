.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.task-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.task-subject {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.task-time {
  font-size: 24rpx;
  color: #999;
}

.task-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.task-details {
  display: flex;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.detail-item {
  padding: 6rpx 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.task-file {
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.file-name {
  display: block;
  font-size: 26rpx;
  color: #666;
  word-break: break-all;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #ccc;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.loading text {
  color: #999;
  font-size: 28rpx;
}
