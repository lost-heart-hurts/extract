.container {
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  margin-bottom: 80rpx;
}

.app-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.button-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.button {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: bold;
  border: none;
}

.primary-button {
  background-color: #fff;
  color: #667eea;
}

.secondary-button {
  background-color: transparent;
  color: #fff;
  border: 2rpx solid #fff;
}
