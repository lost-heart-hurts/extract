.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  margin-bottom: 70rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 54rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.form-section {
  background-color: #fff;
  border-radius: 15rpx;
  min-width: 75vw;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #fff;
  box-sizing: border-box;
}

.preview-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.preview-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.preview-text {
  display: block;
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
}

.button-group {
  display: flex;
  gap: 20rpx;
  margin: 40rpx -40rpx 20rpx;
  padding: 0 40rpx;
}

.button {
  flex: 1;
  width: 300rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 34rpx;
  border: none;
  padding: 0 30rpx;
  margin: 0;
  min-height: 100rpx;
  display: block;
  box-sizing: border-box;
}

.button::after {
  border: none;
}

.primary-button {
  background-color: #07c160;
  color: #fff;
}

.secondary-button {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #e0e0e0;
}
