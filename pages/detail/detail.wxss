.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading text {
  color: #999;
  font-size: 28rpx;
}

.header {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-badge {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.task-id {
  font-size: 24rpx;
  color: #999;
}

.info-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.file-name {
  max-width: 400rpx;
  text-align: right;
  word-break: break-all;
}

.error-section {
  background-color: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.error-label {
  display: block;
  font-size: 28rpx;
  color: #f5222d;
  margin-bottom: 15rpx;
}

.error-message {
  display: block;
  font-size: 26rpx;
  color: #ff4d4f;
  word-break: break-all;
}

.action-section {
  margin-top: 40rpx;
}

.button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
  margin-bottom: 20rpx;
}

.primary-button {
  background-color: #07c160;
  color: #fff;
}

.secondary-button {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}
